{
    //# Rename this file to appsettings.Development.json and replace MACHINENAME with your machine hostname.
    //# Your machine hostname is the value of $env:COMPUTERNAME in PowerShell.
    //# The certificate CN=MACHINENAME.quidgest.pt must exist in LocalMachine\My (issued automatically by the company domain).
    //# Make sure your user account has read access to the private key of that certificate in LocalMachine\My.
    "Kestrel": {
        "Endpoints": {
            "Https": {
                "Url": "https://*:7015",
                "Certificate": {
                    "Subject": "MACHINENAME.quidgest.pt",
                    "Store": "My",
                    "Location": "LocalMachine",
                    "AllowInvalid": false
                }
            }
        }
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    }
}
